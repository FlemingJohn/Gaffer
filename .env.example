# Gaffer environment configuration
# Copy to `.env` and adjust. Everything runs on-device — no cloud API keys exist by design.

# Reproducible P2P identity seed (64-char hex). Only needed for the optional
# delegated-inference / stadium-mesh stretch feature.
# QVAC_HYPERSWARM_SEED=

# Force GPU offload for inference where available ("gpu" | "cpu"). Defaults to cpu-safe.
GAFFER_DEVICE=cpu

# Verbose SDK + pipeline logging (the QVAC SDK is silent by default in v0.14).
GAFFER_DEBUG=false
